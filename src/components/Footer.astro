---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-dt-darker/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-dt-green" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2.5"/>
          <path d="M10 20 C10 20, 13 24, 16 24 C19 24, 22 20, 22 20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
        <span class="text-sm text-dt-light/50">
          &copy; {year} Double Trouble Company
        </span>
      </div>
      <p class="text-xs text-dt-light/30">
        Hecho para divertirse con amigos
      </p>
    </div>
  </div>
</footer>
