---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  status?: 'available' | 'coming-soon';
  gradient?: string;
}

const { title, description, href, icon = '🎮', status = 'coming-soon', gradient = 'from-dt-purple to-dt-pink' } = Astro.props;
---

<a
  href={status === 'available' ? href : '#'}
  class={`group relative block rounded-2xl border border-white/10 bg-dt-darker/50 p-6 transition-all duration-300 hover:border-white/20 hover:bg-dt-darker/80 ${status === 'available' ? 'cursor-pointer' : 'cursor-default'}`}
>
  <div class="flex items-start justify-between mb-4">
    <span class="text-4xl">{icon}</span>
    {status === 'coming-soon' && (
      <span class="text-xs font-medium px-2 py-1 rounded-full bg-dt-purple/10 text-dt-purple border border-dt-purple/20">
        Próximamente
      </span>
    )}
    {status === 'available' && (
      <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-500/10 text-green-400 border border-green-500/20">
        Disponible
      </span>
    )}
  </div>

  <h3 class="text-lg font-semibold text-dt-light mb-2 group-hover:bg-gradient-to-r group-hover:{gradient} group-hover:bg-clip-text group-hover:text-transparent transition-all duration-300">
    {title}
  </h3>

  <p class="text-sm text-dt-light/50 leading-relaxed">
    {description}
  </p>

  {status === 'available' && (
    <div class={`mt-4 inline-flex items-center gap-1 text-sm font-medium bg-gradient-to-r ${gradient} bg-clip-text text-transparent`}>
      Jugar
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </div>
  )}
</a>
