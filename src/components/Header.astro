---
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-dt-dark/70 border-b border-white/5">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group" aria-label="Ir al inicio">
      <svg class="w-8 h-8 text-dt-green group-hover:text-dt-green-light transition-colors duration-300" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2.5"/>
        <path d="M10 20 C10 20, 13 24, 16 24 C19 24, 22 20, 22 20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
        <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
      </svg>
      <span class="text-lg font-bold text-dt-green">
        Double Trouble
      </span>
    </a>

    <div class="flex items-center gap-6">
      <a href="/" class="text-sm font-medium text-dt-light/70 hover:text-dt-green transition-colors duration-200 nav-link">
        Inicio
      </a>
      <a href="/games" class="text-sm font-medium text-dt-light/70 hover:text-dt-green-light transition-colors duration-200">
        Juegos
      </a>
    </div>
  </nav>
</header>

<script>
  document.querySelectorAll('.nav-link').forEach((link) => {
    if (link.pathname === location.pathname) {
      link.setAttribute('aria-current', 'page');
    }
  });
</script>
