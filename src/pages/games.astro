---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
---

<Layout title="Juegos - Double Trouble Company" description="Explora todos los minijuegos disponibles para jugar con tus amigos">

  <section class="min-h-screen pt-24 pb-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-black text-dt-light mb-4">
          Minijuegos
        </h1>
        <p class="text-dt-light/50 max-w-md mx-auto">
          Elige un juego, invita a tus amigos y que comience la diversión
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <GameCard
          title="Tragachupitos"
          description="Máquina tragaperras. Si salen 3 vasos... ¡te toca beber!"
          icon="🎰"
          status="available"
          href="/games/traga-chupitos"
        />
      </div>
    </div>
  </section>
</Layout>
