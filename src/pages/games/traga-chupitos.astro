---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Tragachupitos - Double Trouble Company" description="Máquina tragaperras de fiesta">

  <section class="min-h-screen pt-24 pb-16 px-4 flex items-center justify-center">
    <div class="w-full max-w-xl mx-auto">

      <!-- ===== MACHINE BODY ===== -->
      <div id="machine" class="relative rounded-2xl border-[3px] border-white/10 bg-gradient-to-b from-zinc-800 via-zinc-900 to-black p-1 shadow-[0_0_80px_-20px_rgba(34,197,94,0.12)]">

        <!-- Chrome inner border -->
        <div class="rounded-xl border border-white/5 bg-gradient-to-b from-zinc-800/50 to-black/80 p-5 sm:p-6">

          <!-- ===== TOP GLASS PANEL ===== -->
          <div class="relative mb-5 rounded-lg border border-white/10 bg-gradient-to-b from-black/80 to-zinc-900/80 p-3 text-center overflow-hidden shadow-inner">
            <div class="absolute inset-0 bg-gradient-to-b from-dt-green/5 to-transparent pointer-events-none" />
            <div class="absolute inset-0 bg-[linear-gradient(110deg,transparent_30%,rgba(255,255,255,0.03)_50%,transparent_70%)] pointer-events-none" />
            <h1 class="text-xl sm:text-2xl font-black text-dt-green tracking-[0.2em] uppercase relative">
              Tragachupitos
            </h1>
            <div class="flex items-center justify-center gap-2 mt-1 relative">
              <span class="w-1.5 h-1.5 rounded-full bg-dt-green shadow-[0_0_6px_#22C55E]" />
              <span class="text-[10px] text-dt-green-light/50 uppercase tracking-[0.3em] font-medium">Jackpot</span>
              <span class="w-1.5 h-1.5 rounded-full bg-dt-green shadow-[0_0_6px_#22C55E]" />
            </div>
          </div>

          <!-- ===== REELS + LEVER ROW ===== -->
          <div class="flex gap-3 items-stretch mb-4">

            <!-- Reels area -->
            <div class="flex-1 grid grid-cols-3 gap-2 sm:gap-3">

              <!-- REEL 1 -->
              <div class="reel-frame relative rounded-lg border-2 border-zinc-600/60 bg-black overflow-hidden shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
                <div class="reel-window" id="window-1">
                  <div class="reel-strip" id="strip-1"></div>
                </div>
                <!-- Chrome reflection overlays -->
                <div class="absolute inset-x-0 top-0 h-5 bg-gradient-to-b from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-x-0 bottom-0 h-5 bg-gradient-to-t from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 left-0 w-3 bg-gradient-to-r from-zinc-800/30 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 right-0 w-3 bg-gradient-to-l from-zinc-800/30 to-transparent pointer-events-none" />
                <!-- Screws -->
                <div class="absolute top-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute top-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
              </div>

              <!-- REEL 2 -->
              <div class="reel-frame relative rounded-lg border-2 border-zinc-600/60 bg-black overflow-hidden shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
                <div class="reel-window" id="window-2">
                  <div class="reel-strip" id="strip-2"></div>
                </div>
                <div class="absolute inset-x-0 top-0 h-5 bg-gradient-to-b from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-x-0 bottom-0 h-5 bg-gradient-to-t from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 left-0 w-3 bg-gradient-to-r from-zinc-800/30 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 right-0 w-3 bg-gradient-to-l from-zinc-800/30 to-transparent pointer-events-none" />
                <div class="absolute top-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute top-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
              </div>

              <!-- REEL 3 -->
              <div class="reel-frame relative rounded-lg border-2 border-zinc-600/60 bg-black overflow-hidden shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
                <div class="reel-window" id="window-3">
                  <div class="reel-strip" id="strip-3"></div>
                </div>
                <div class="absolute inset-x-0 top-0 h-5 bg-gradient-to-b from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-x-0 bottom-0 h-5 bg-gradient-to-t from-zinc-800/40 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 left-0 w-3 bg-gradient-to-r from-zinc-800/30 to-transparent pointer-events-none" />
                <div class="absolute inset-y-0 right-0 w-3 bg-gradient-to-l from-zinc-800/30 to-transparent pointer-events-none" />
                <div class="absolute top-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute top-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 left-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
                <div class="absolute bottom-1 right-1 w-2 h-2 rounded-full bg-zinc-600/50 border border-zinc-500/30" />
              </div>

              <!-- Payline indicator -->
              <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 pointer-events-none flex items-center justify-center gap-2 sm:gap-3 z-10">
                <div class="flex-1 h-[2px] bg-dt-green/20" />
                <div class="w-3 h-3 rounded-full border-2 border-dt-green/30 bg-dt-green/10 shadow-[0_0_10px_rgba(34,197,94,0.2)]" />
                <div class="flex-1 h-[2px] bg-dt-green/20" />
              </div>
            </div>

            <!-- ===== LEVER ===== -->
            <div class="relative w-12 sm:w-14 flex flex-col items-center justify-end pb-2">
              <!-- Lever track -->
              <div class="absolute top-0 bottom-3 w-1.5 rounded-full bg-gradient-to-b from-zinc-700 to-zinc-800 border border-zinc-600/30" />
              <!-- Lever assembly -->
              <div class="relative z-10 flex flex-col items-center cursor-pointer select-none" id="lever" role="button" tabindex="0" aria-label="Tirar palanca">
                <!-- Lever ball (RED) -->
                <div id="lever-ball" class="relative w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gradient-to-br from-red-400 via-red-500 to-red-700 shadow-[0_0_15px_rgba(239,68,68,0.3)] border border-red-300/30 flex items-center justify-center">
                  <div class="w-5 h-5 sm:w-6 sm:h-6 rounded-full bg-gradient-to-br from-white/20 to-transparent" />
                  <div class="absolute top-1 w-3 h-1 rounded-full bg-white/20" />
                </div>
                <!-- Lever shaft -->
                <div id="lever-stick" class="w-2 h-20 sm:h-24 rounded-full bg-gradient-to-b from-zinc-300 via-zinc-400 to-zinc-500 border border-zinc-200/20 shadow-inner" />
                <!-- Lever base -->
                <div class="w-6 h-3 rounded-b bg-gradient-to-b from-zinc-600 to-zinc-700 border border-zinc-500/30 shadow-inner" />
              </div>
            </div>
          </div>

          <!-- ===== RESULT MESSAGE ===== -->
          <div id="result-display" class="relative mb-4 rounded-md border border-white/5 bg-black/40 p-2.5 text-center min-h-[2.5rem] flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-dt-green/[0.02] to-transparent pointer-events-none" />
            <p id="result-message" class="text-sm font-medium text-zinc-500 relative">
              ¡Tira de la palanca!
            </p>
          </div>

          <!-- ===== GLASS BUTTONS ===== -->
          <div class="flex items-center justify-center gap-4 sm:gap-6 mb-4">
            <button id="spin-btn" class="glass-btn group relative px-6 sm:px-8 py-2.5 rounded-full text-sm font-bold text-white uppercase tracking-wider disabled:opacity-30 disabled:cursor-not-allowed">
              <span class="relative z-10 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Jugar
              </span>
            </button>

            <button id="reset-btn" class="glass-btn-sm group relative px-5 py-2 rounded-full text-xs font-semibold text-zinc-400 uppercase tracking-wider">
              <span class="relative z-10 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Reset
              </span>
            </button>
          </div>

          <!-- ===== STATS ===== -->
          <div class="flex items-center justify-center gap-6 text-[11px] text-zinc-500">
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-dt-green/40" />
              💧 Bebidas: <span id="drink-count" class="text-dt-green-light font-semibold">0</span>
            </span>
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-dt-green-light/40" />
              🎰 Tiradas: <span id="spin-count" class="text-dt-green-light font-semibold">0</span>
            </span>
          </div>
        </div>
      </div>

      <!-- Symbols legend -->
      <div class="mt-3 text-center text-[10px] text-zinc-600">
        🍒 🍋 🍊 🍇 🍉 🥃
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* ===== REEL STRIP ===== */
  .reel-window {
    height: calc(var(--sym-h, 56px) * 3);
    overflow: hidden;
    position: relative;
  }
  .reel-strip {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .reel-strip .sym {
    height: var(--sym-h, 56px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: calc(var(--sym-h, 56px) * 0.6);
    line-height: 1;
    flex-shrink: 0;
    user-select: none;
  }

  /* ===== MACHINE WIN GLOW ===== */
  #machine.win {
    animation: winGlow 1s ease-in-out 4;
  }
  @keyframes winGlow {
    0%, 100% { box-shadow: 0 0 80px -20px rgba(34,197,94,0.12); }
    50% { box-shadow: 0 0 100px 0px rgba(34,197,94,0.45); }
  }

  #result-message.win {
    animation: resultPop 0.5s ease-out;
    color: #6EE7B7;
  }
  @keyframes resultPop {
    0% { transform: scale(0.8); opacity: 0; }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }

  /* ===== MACHINE SHAKE ===== */
  #machine.shake {
    animation: shake 0.3s ease-in-out;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-2px) rotate(-0.3deg); }
    40% { transform: translateX(2px) rotate(0.3deg); }
    60% { transform: translateX(-1px) rotate(-0.1deg); }
    80% { transform: translateX(1px) rotate(0.1deg); }
  }

  /* ===== GLASS BUTTONS ===== */
  .glass-btn {
    background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(16,185,129,0.08));
    border: 1px solid rgba(34,197,94,0.2);
    box-shadow:
      0 2px 10px rgba(34,197,94,0.1),
      inset 0 1px 0 rgba(255,255,255,0.1),
      inset 0 -1px 0 rgba(0,0,0,0.1);
    transition: all 0.2s;
    backdrop-filter: blur(4px);
    position: relative;
    overflow: hidden;
  }
  .glass-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 35%, rgba(255,255,255,0.08) 50%, transparent 65%);
    background-size: 200% 100%;
    background-position: 100% 0;
    transition: background-position 0.4s;
  }
  .glass-btn:hover:not(:disabled) {
    background: linear-gradient(135deg, rgba(34,197,94,0.25), rgba(16,185,129,0.15));
    border-color: rgba(34,197,94,0.4);
    box-shadow:
      0 4px 20px rgba(34,197,94,0.2),
      inset 0 1px 0 rgba(255,255,255,0.15);
    transform: translateY(-1px);
  }
  .glass-btn:hover:not(:disabled)::before {
    background-position: 0 0;
  }
  .glass-btn:active:not(:disabled) {
    transform: translateY(1px);
    box-shadow:
      0 1px 5px rgba(34,197,94,0.1),
      inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .glass-btn-sm {
    background: linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    transition: all 0.2s;
    backdrop-filter: blur(4px);
    position: relative;
    overflow: hidden;
  }
  .glass-btn-sm::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 35%, rgba(255,255,255,0.05) 50%, transparent 65%);
    background-size: 200% 100%;
    background-position: 100% 0;
    transition: background-position 0.4s;
  }
  .glass-btn-sm:hover {
    background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-1px);
  }
  .glass-btn-sm:hover::before {
    background-position: 0 0;
  }

  /* ===== REEL FRAME LIGHTING ===== */
  .reel-frame {
    transition: border-color 0.3s;
  }
  #machine.win .reel-frame {
    border-color: rgba(34,197,94,0.4) !important;
  }

  /* ===== WIN CONFETTI OVERLAY ===== */
  .confetti-piece {
    position: fixed;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    pointer-events: none;
    z-index: 100;
  }

  /* ===== SPARKS ===== */
  .spark {
    position: fixed;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 200;
    box-shadow: 0 0 6px 2px currentColor;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 480px) {
    .reel-window {
      height: calc(var(--sym-h, 44px) * 3);
    }
    .reel-strip .sym {
      font-size: calc(var(--sym-h, 44px) * 0.55);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  // ===== CONFIG =====
  const SYMBOLS = ['🍒', '🍋', '🍊', '🍇', '🍉', '🥃'];
  const STRIP_LEN = 42;
  const TARGET_INDEX = 38;
  const WIN_SYMBOL = '🥃';

  // ===== DOM REFS =====
  const strips = [1, 2, 3].map((i) => document.getElementById(`strip-${i}`));
  const windows = [1, 2, 3].map((i) => document.getElementById(`window-${i}`));
  const lever = document.getElementById('lever');
  const leverBall = document.getElementById('lever-ball');
  const leverStick = document.getElementById('lever-stick');
  const spinBtn = document.getElementById('spin-btn');
  const resetBtn = document.getElementById('reset-btn');
  const resultMsg = document.getElementById('result-message');
  const resultDisp = document.getElementById('result-display');
  const drinkCount = document.getElementById('drink-count');
  const spinCount = document.getElementById('spin-count');
  const machine = document.getElementById('machine');

  // ===== STATE =====
  let isSpinning = false;
  let drinks = 0;
  let spins = 0;
  let symbolHeight = 56;

  // ===== SOUND ENGINE =====
  const Sound = {
    ctx: null,
    _init() {
      if (!this.ctx) {
        this.ctx = new (window.AudioContext || window.webkitAudioContext)();
        if (this.ctx.state === 'suspended') this.ctx.resume();
      }
      if (this.ctx.state === 'suspended') this.ctx.resume();
      return this.ctx;
    },
    tick() {
      try {
        const c = this._init();
        const o = c.createOscillator();
        const g = c.createGain();
        o.connect(g);
        g.connect(c.destination);
        o.type = 'triangle';
        o.frequency.setValueAtTime(1500 + Math.random() * 500, c.currentTime);
        g.gain.setValueAtTime(0.03, c.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + 0.025);
        o.start(c.currentTime);
        o.stop(c.currentTime + 0.025);
      } catch {}
    },
    stopClunk() {
      try {
        const c = this._init();
        const o = c.createOscillator();
        const g = c.createGain();
        o.connect(g);
        g.connect(c.destination);
        o.type = 'sine';
        o.frequency.setValueAtTime(120, c.currentTime);
        o.frequency.exponentialRampToValueAtTime(40, c.currentTime + 0.2);
        g.gain.setValueAtTime(0.15, c.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + 0.2);
        o.start(c.currentTime);
        o.stop(c.currentTime + 0.2);
        // Add click layer
        const n = c.createBufferSource();
        const buf = c.createBuffer(1, c.sampleRate * 0.03, c.sampleRate);
        const data = buf.getChannelData(0);
        for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (c.sampleRate * 0.008));
        n.buffer = buf;
        const ng = c.createGain();
        n.connect(ng);
        ng.connect(c.destination);
        ng.gain.setValueAtTime(0.06, c.currentTime);
        n.start(c.currentTime);
      } catch {}
    },
    leverClick() {
      try {
        const c = this._init();
        const o = c.createOscillator();
        const g = c.createGain();
        o.connect(g);
        g.connect(c.destination);
        o.type = 'square';
        o.frequency.setValueAtTime(600, c.currentTime);
        o.frequency.exponentialRampToValueAtTime(200, c.currentTime + 0.06);
        g.gain.setValueAtTime(0.04, c.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + 0.06);
        o.start(c.currentTime);
        o.stop(c.currentTime + 0.06);
      } catch {}
    },
    leverSpring() {
      try {
        const c = this._init();
        const o = c.createOscillator();
        const g = c.createGain();
        o.connect(g);
        g.connect(c.destination);
        o.type = 'sine';
        o.frequency.setValueAtTime(800, c.currentTime);
        o.frequency.exponentialRampToValueAtTime(1200, c.currentTime + 0.05);
        g.gain.setValueAtTime(0.02, c.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + 0.08);
        o.start(c.currentTime);
        o.stop(c.currentTime + 0.08);
      } catch {}
    },
    win() {
      try {
        const c = this._init();
        const notes = [523, 659, 784, 1047, 1319, 1568];
        notes.forEach((freq, i) => {
          const o = c.createOscillator();
          const g = c.createGain();
          o.connect(g);
          g.connect(c.destination);
          o.type = 'sine';
          const t = c.currentTime + i * 0.1;
          o.frequency.setValueAtTime(freq, t);
          g.gain.setValueAtTime(0.06, t);
          g.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
          o.start(t);
          o.stop(t + 0.3);
        });
      } catch {}
    },
    lose() {
      try {
        const c = this._init();
        const notes = [400, 350, 300, 250];
        notes.forEach((freq, i) => {
          const o = c.createOscillator();
          const g = c.createGain();
          o.connect(g);
          g.connect(c.destination);
          o.type = 'sawtooth';
          const t = c.currentTime + i * 0.12;
          o.frequency.setValueAtTime(freq, t);
          g.gain.setValueAtTime(0.02, t);
          g.gain.exponentialRampToValueAtTime(0.001, t + 0.2);
          o.start(t);
          o.stop(t + 0.2);
        });
      } catch {}
    },
    reelStart() {
      try {
        const c = this._init();
        const o = c.createOscillator();
        const g = c.createGain();
        o.connect(g);
        g.connect(c.destination);
        o.type = 'sawtooth';
        o.frequency.setValueAtTime(100, c.currentTime);
        o.frequency.linearRampToValueAtTime(300, c.currentTime + 0.15);
        g.gain.setValueAtTime(0.03, c.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + 0.2);
        o.start(c.currentTime);
        o.stop(c.currentTime + 0.2);
      } catch {}
    },
  };

  // ===== MATH HELPERS =====
  function rand(n) { return Math.floor(Math.random() * n); }

  function getRandomSymbol() {
    return SYMBOLS[rand(SYMBOLS.length)];
  }

  function randomSymbols(n) {
    return Array.from({ length: n }, getRandomSymbol);
  }

  // ===== BUILD REEL STRIP =====
  function buildStrip(el, resultSymbol) {
    const symbols = randomSymbols(STRIP_LEN);
    symbols[TARGET_INDEX - 1] = resultSymbol;
    symbols[TARGET_INDEX] = resultSymbol;
    symbols[TARGET_INDEX + 1] = resultSymbol;

    el.innerHTML = symbols.map((s) => `<span class="sym">${s}</span>`).join('');
    el.style.transform = 'translateY(0)';

    const h = symbolHeight;
    const windowH = h * 3;
    const targetY = -(TARGET_INDEX * h) + (windowH - h) / 2;

    return { targetY, symbols };
  }

  // ===== SPIN A SINGLE REEL =====
  function spinStrip(el, targetY, duration) {
    return new Promise((resolve) => {
      gsap.to(el, {
        y: targetY,
        duration,
        ease: 'power4.out',
        onComplete() {
          resolve();
        },
      });
    });
  }

  // ===== CONFETTI =====
  function fireConfetti() {
    const colors = ['#22C55E', '#6EE7B7', '#10B981', '#34D399', '#FDE68A', '#FCA5A5'];
    for (let i = 0; i < 60; i++) {
      const piece = document.createElement('div');
      piece.className = 'confetti-piece';
      const color = colors[rand(colors.length)];
      const left = Math.random() * 100;
      const size = 4 + Math.random() * 6;
      piece.style.cssText = `
        left: ${left}vw;
        top: -20px;
        width: ${size}px;
        height: ${size * 0.6}px;
        background: ${color};
        border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
        opacity: 1;
      `;
      document.body.appendChild(piece);

      gsap.to(piece, {
        y: window.innerHeight + 100,
        x: (Math.random() - 0.5) * 200,
        rotation: Math.random() * 720 - 360,
        duration: 2 + Math.random() * 1.5,
        delay: Math.random() * 0.5,
        ease: 'power2.out',
        onComplete() { piece.remove(); },
      });
    }
  }

  // ===== SPARKS =====
  function fireSparks(count = 30) {
    const rect = lever.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    const colors = ['#FDE047', '#F59E0B', '#F97316', '#FEF3C7', '#FFFBEB'];

    for (let i = 0; i < count; i++) {
      const spark = document.createElement('div');
      spark.className = 'spark';
      const color = colors[rand(colors.length)];
      const angle = Math.random() * Math.PI * 2;
      const dist = 30 + Math.random() * 120;
      const size = 3 + Math.random() * 5;
      spark.style.cssText = `
        left: ${cx}px;
        top: ${cy}px;
        width: ${size}px;
        height: ${size}px;
        color: ${color};
        background: ${color};
        opacity: 1;
      `;
      document.body.appendChild(spark);

      gsap.to(spark, {
        x: Math.cos(angle) * dist,
        y: Math.sin(angle) * dist,
        opacity: 0,
        scale: 0.3,
        duration: 0.4 + Math.random() * 0.5,
        delay: Math.random() * 0.08,
        ease: 'power2.out',
        onComplete() { spark.remove(); },
      });
    }
  }

  // ===== MAIN SPIN =====
  async function spin() {
    if (isSpinning) return;
    isSpinning = true;
    spinBtn.disabled = true;
    machine.classList.remove('win', 'shake');
    resultMsg.className = 'text-sm font-medium text-zinc-500';

    // Init audio on interaction
    Sound._init();

    spins++;
    spinCount.textContent = spins;

    // Results
    const results = [getRandomSymbol(), getRandomSymbol(), getRandomSymbol()];
    const isWin = results.every((s) => s === WIN_SYMBOL);

    // Build fresh strips (hidden during lever pull)
    const data = strips.map((el, i) => buildStrip(el, results[i]));

    // Determine sizes
    const el = strips[0];
    const h = el.querySelector('.sym')?.offsetHeight || 56;
    symbolHeight = h;

    // Rebuild with correct height
    strips.forEach((el, i) => {
      const d = buildStrip(el, results[i]);
      data[i] = d;
    });

    window.requestAnimationFrame(() => {
      document.documentElement.style.setProperty('--sym-h', symbolHeight + 'px');
    });

    // ---- LEVER PULL ----
    Sound.leverClick();
    fireSparks(35);
    gsap.to(leverBall, { y: 38, duration: 0.1, ease: 'power2.in' });
    gsap.to(leverStick, { scaleY: 0.15, transformOrigin: 'bottom center', duration: 0.1, ease: 'power2.in' });

    machine.classList.add('shake');

    // Lever spring back
    await new Promise((r) => setTimeout(r, 100));
    Sound.leverSpring();
    gsap.to(leverBall, { y: 0, duration: 0.35, ease: 'bounce.out' });
    gsap.to(leverStick, { scaleY: 1, duration: 0.35, ease: 'bounce.out' });

    machine.classList.remove('shake');

    // Small pause for tension
    await new Promise((r) => setTimeout(r, 200));

    // ---- REELS SPIN ----
    resultMsg.textContent = '🎰 Girando...';
    Sound.reelStart();

    const reelDuration = 1800;

    // Start all reels, wait for all
    const reelPromises = strips.map((el, i) => {
      const delay = i * 350;
      const dur = reelDuration + i * 200;
      return new Promise((resolve) => {
        setTimeout(() => {
          spinStrip(el, data[i].targetY, dur / 1000).then(resolve);
        }, delay);
      });
    });

    // Tick sounds during spin
    let tickInterval;
    const startTick = () => {
      let tickCount = 0;
      tickInterval = setInterval(() => {
        Sound.tick();
        tickCount++;
        if (tickCount > 90) clearInterval(tickInterval);
      }, 50);
    };
    startTick();

    // Slow down ticks
    for (let t = 1; t <= 3; t++) {
      await new Promise((r) => setTimeout(r, 500 + t * 400));
      clearInterval(tickInterval);
      Sound.stopClunk();
      if (t < 3) {
        tickInterval = setInterval(() => {
          Sound.tick();
        }, 80 + t * 30);
      }
    }

    await Promise.all(reelPromises);
    clearInterval(tickInterval);

    // ---- RESULT ----
    if (isWin) {
      drinks++;
      drinkCount.textContent = drinks;
      resultMsg.className = 'text-lg font-bold text-dt-green-light win text-center';
      resultMsg.textContent = '🥃 ¡BEBE UN CHUPITO! 🥃';
      machine.classList.add('win');
      Sound.win();
      fireConfetti();
    } else {
      const shotCount = results.filter((s) => s === WIN_SYMBOL).length;
      if (shotCount === 2) {
        resultMsg.textContent = '🥃🥃 ¡Casi! ¡Por uno!';
        Sound.lose();
      } else if (shotCount === 1) {
        resultMsg.textContent = '🥃 Un vaso... casi nada';
        Sound.lose();
      } else {
        const noneMsgs = ['😅 Nada... ¡Otra vez!', '🙃 Inténtalo de nuevo', '🤷‍♂️ Ni uno', '😬 La próxima será'];
        resultMsg.textContent = noneMsgs[rand(noneMsgs.length)];
        Sound.lose();
      }
    }

    isSpinning = false;
    spinBtn.disabled = false;
  }

  // ===== RESET =====
  function reset() {
    if (isSpinning) return;
    drinks = 0;
    spins = 0;
    drinkCount.textContent = '0';
    spinCount.textContent = '0';
    resultMsg.className = 'text-sm font-medium text-zinc-500';
    resultMsg.textContent = 'Contadores reiniciados';
    machine.classList.remove('win');
  }

  // ===== EVENTS =====
  lever.addEventListener('click', spin);
  spinBtn.addEventListener('click', spin);
  resetBtn.addEventListener('click', reset);

  lever.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); spin(); }
  });

  // ===== INIT =====
  (function init() {
    const initialSymbols = ['🍒', '🍋', '🍊'];
    strips.forEach((el, i) => {
      const s = initialSymbols[i] || getRandomSymbol();
      buildStrip(el, s);
    });
    window.requestAnimationFrame(() => {
      const h = strips[0].querySelector('.sym')?.offsetHeight || 56;
      symbolHeight = h;
      document.documentElement.style.setProperty('--sym-h', h + 'px');
    });
  })();
</script>
